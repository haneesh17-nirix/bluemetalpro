# Weighbridge Identity
WEIGHBRIDGE_ID=wb-001
WEIGHBRIDGE_NAME=Main Gate Scale
WEIGHBRIDGE_API_KEY=generate-a-random-secret-here
LOCATION_LABEL=Main gate

# Serial Port (legacy RS-232/USB)
COM_PORT=COM3
BAUD_RATE=9600
MAX_CAPACITY_KG=60000

# BlueMetal Pro Cloud API
API_URL=https://bluemetal-prod-api.azurewebsites.net/api

# Local servers (LAN only)
WS_PORT=8765
HTTP_PORT=8766
