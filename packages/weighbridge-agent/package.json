{
  "name": "@bluemetal/weighbridge-agent",
  "version": "1.14.7",
  "description": "On-site edge agent \u2014 reads serial/USB weighbridge and pushes to BlueMetal Pro cloud",
  "main": "dist/index.js",
  "bin": {
    "bluemetal-agent": "dist/index.js"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "install-service": "node dist/install-service.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "serialport": "^12.0.0",
    "axios": "^1.6.8",
    "dotenv": "^16.3.1",
    "node-cron": "^3.0.3",
    "ws": "^8.16.0",
    "node-windows": "^1.0.0-beta.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.4.0",
    "ts-node-dev": "^2.0.0"
  }
}
